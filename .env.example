# Copy to .env and fill in - never commit .env

# Anthropic API key (from console.anthropic.com) - NOT your Claude Pro/Claude
# Code login, a separate API key is required for programmatic Messages API calls.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-5

# paper | live - always starts in paper, change deliberately in the dashboard
# or here, never automatically.
TRADING_MODE=paper

# Starting virtual cash balance for paper trading
PAPER_STARTING_CASH=10000

# Risk limits (all editable later from the dashboard)
MAX_POSITION_PCT=0.05
MAX_DAILY_LOSS_PCT=0.02
MAX_OPEN_POSITIONS=8
ALLOW_OPTIONS=false

# How often the decision loop runs, in minutes, during market hours (9:30-16:00 ET)
TICK_INTERVAL_MINUTES=15

# Robinhood live trading (Phase 2)
ROBINHOOD_MCP_URL=https://agent.robinhood.com/mcp/trading
# Where OAuth tokens from scripts/robinhood_oauth_setup.py are saved -
# gitignored (see secrets/), needs to survive container rebuilds.
ROBINHOOD_TOKEN_FILE=secrets/robinhood_tokens.json
# Safety net: even with TRADING_MODE=live, RobinhoodBroker only calls
# Robinhood's own review_equity_order (a pre-trade simulation that
# never executes) while this is true - place_equity_order (the real
# fill) is skipped, but decisions/reasoning still populate the
# dashboard so live-mode behavior can be compared against paper before
# it's trusted with real money. Only flip this deliberately.
LIVE_DRY_RUN=true

# HTTP Basic Auth on the whole app (defense in depth for LAN/Tailscale
# direct access, bypassing Cloudflare Access). Users live in the
# dashboard_users DB table, managed from the /users page. These two
# vars are ONLY used to bootstrap the first account when that table is
# empty (fresh deploy) - once any user exists, they're never read
# again. App refuses to start if the table is empty and this password
# is blank - set a real password, not this placeholder.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=changeme
